rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. GLOBAL SAFETY NET: Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- REUSABLE SECURITY PRIMITIVES ---
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserEmail() {
      return isSignedIn() && "email" in request.auth.token ? request.auth.token.email.lower() : null;
    }

    // Fetch user profile based on the authenticated user's email
    function getUserDoc() {
      return get(/databases/$(database)/documents/users/$(getUserEmail())).data;
    }

    // Helper to determine if the authenticated user has the 'admin' role
    function isAdmin() {
      return isSignedIn() && (
        getUserEmail() == 'payalyt6279@gmail.com' ||
        getUserEmail() == 'admin@goloballottery.com' ||
        (exists(/databases/$(database)/documents/users/$(getUserEmail())) && 
         get(/databases/$(database)/documents/users/$(getUserEmail())).data.role == 'admin')
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- USERS COLLECTION ---
    match /users/{email} {
      // Allow individual document retrieval for login fallback and profile viewing
      allow get: if true;
      
      // Only signed-in users or admins can list all users
      allow list: if isSignedIn() && isAdmin();
      
      // Anyone can register a new profile
      allow create: if true;

      // Users can modify non-sensitive profile fields, and only DECREASE their balance/winnings (never self-credit)
      allow update: if isSignedIn() && (
        isAdmin() || (
          (getUserEmail() == email || incoming().uid == request.auth.uid) &&
          incoming().role == 'user' &&
          incoming().balance <= existing().balance &&
          (!('winningsBalance' in incoming()) || incoming().winningsBalance <= existing().winningsBalance) &&
          (!('commissionBalance' in incoming()) || incoming().commissionBalance <= existing().commissionBalance)
        )
      );

      allow delete: if isSignedIn() && isAdmin();
    }

    // --- DEPOSIT REQUESTS ---
    match /depositRequests/{requestId} {
      allow read: if isSignedIn() && (getUserEmail() == resource.data.email || isAdmin());
      
      // Users can create standard pending deposit requests for themselves
      allow create: if isSignedIn() && 
                    getUserEmail() == incoming().email && 
                    incoming().status == 'Pending' &&
                    isValidId(requestId);

      // Only admins can approve, reject or modify deposit request ledgers
      allow update, delete: if isSignedIn() && isAdmin();
    }

    // --- WITHDRAWAL REQUESTS ---
    match /withdrawalRequests/{requestId} {
      allow read: if isSignedIn() && (getUserEmail() == resource.data.email || isAdmin());
      
      // Users can create standard pending withdrawal requests for themselves
      allow create: if isSignedIn() && 
                    getUserEmail() == incoming().email && 
                    incoming().status == 'Pending' &&
                    isValidId(requestId);

      // Only admins can approve, reject or modify withdrawal request ledgers
      allow update, delete: if isSignedIn() && isAdmin();
    }

    // --- PURCHASED TICKETS ---
    match /purchasedTickets/{ticketId} {
      allow read: if isSignedIn() && (getUserEmail() == resource.data.email || isAdmin());
      
      // Users can create standard pending purchased ticket entries for themselves
      allow create: if isSignedIn() && 
                    getUserEmail() == incoming().email && 
                    incoming().status == 'Pending';

      // Only admins can modify ticket status (e.g. marking as Won/Lost and calculating payouts)
      allow update, delete: if isSignedIn() && isAdmin();
    }

    // --- HISTORICAL DRAWS (PUBLIC DATA) ---
    match /historicalDraws/{drawId} {
      allow read: if true;
      allow write: if isSignedIn() && isAdmin();
    }

    // --- DAILY RAFFLE WINNERS (PUBLIC DATA) ---
    match /raffleWinners/{winnerId} {
      allow read: if true;
      allow write: if isSignedIn() && isAdmin();
    }

    // --- SITE THEME CONFIGS (PUBLIC CONFIGURATION) ---
    match /siteConfigs/{configId} {
      allow read: if true;
      allow write: if isSignedIn() && isAdmin();
    }

    // --- DYNAMIC GAMES (PUBLIC CONFIGURATION) ---
    match /dynamicGames/{gameName} {
      allow read: if true;
      allow write: if isSignedIn() && isAdmin();
    }
  }
}
